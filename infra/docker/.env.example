# ========================================
# Database Configuration
# ========================================
AUTHZ_DB_URL=jdbc:postgresql://postgres:5432/authz
AUTHZ_DB_USER=authz
AUTHZ_DB_PASS=authz

# ========================================
# CyberArk (OAuth2 / OIDC)
# ========================================
# Issuer URL (internal container-to-container communication)
CYBERARK_ISSUER=http://cyberark-mock:8080/default

# Issuer URL exposed by the gateway for browser-based OIDC flows
CYBERARK_ISSUER_PUBLIC=http://localhost/default

# Client credentials for service-to-service calls
CYBERARK_CLIENT_ID=authz-platform
CYBERARK_CLIENT_SECRET=dev-secret

# User API endpoint (for user search in PAP UI)
CYBERARK_USER_API_BASE_URL=http://cyberark-mock:8080/api/users

# ========================================
# OIDC Client Configuration (App Shell)
# ========================================
OIDC_CLIENT_ID=app-shell
OIDC_REDIRECT_URI=http://localhost/callback
OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost

# ========================================
# AuthZ Service Module Keys
# ========================================
# These keys are generated when you create a module via POST /v1/modules
# They are displayed ONCE and must be securely stored.
# After running infra/docker/bootstrap/seed-modules.http, copy the keys here.

# Module: vendas
AUTHZ_MODULE_KEY_VENDAS=changeme-replace-after-module-creation

# Module: estoque
AUTHZ_MODULE_KEY_ESTOQUE=changeme-replace-after-module-creation

# ========================================
# AuthZ Service Configuration
# ========================================
AUTHZ_SERVICE_BASE_URL=http://authz-service:8081
AUTHZ_SERVICE_PUBLIC_URL=http://localhost/api

# ========================================
# Observability (Optional - for dev)
# ========================================
# OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
# OTEL_SERVICE_NAME=authz-service
# OTEL_TRACES_SAMPLER=always_on
# OTEL_LOGS_EXPORTER=otlp
# OTEL_METRICS_EXPORTER=prometheus

# ========================================
# Notes
# ========================================
# 1. Copy this file to .env and fill in the values
# 2. The .env file is gitignored and should NEVER be committed
# 3. Module keys are generated by the AuthZ Service admin API
# 4. To generate module keys, follow the bootstrap process:
#    a. Start postgres, cyberark-mock, authz-service
#    b. Run infra/docker/bootstrap/seed-modules.http
#    c. Copy the returned keys to this file
#    d. Restart demo services with the new keys
